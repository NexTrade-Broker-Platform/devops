# Shared broker secrets
JWT_SECRET=change-this-to-a-long-secret-minimum-32-chars
INTERNAL_API_KEY=dev-internal-api-key

# Broker DB passwords
AUTH_DB_PASSWORD=auth_password
WALLET_DB_PASSWORD=wallet_password
ORDER_DB_PASSWORD=order_password
PORTFOLIO_DB_PASSWORD=portfolio_password
FEE_DB_PASSWORD=fee_password

# Frontend / CORS
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5175

# Exchange credentials issued by exchange/admin panel
EXCHANGE_API_KEY=dev-exchange-key
EXCHANGE_API_SECRET=dev-exchange-secret

# For broker-only these may be dummy.
# For local exchange, defaults are service DNS names from the exchange docker network.
# For deployed exchange, set real public HTTPS/WSS URLs.
EXCHANGE_REST_URL=http://rest-api:8080/api/v1
EXCHANGE_WS_URI=ws://websocket-server:8080/ws

# Local exchange docker network name. Must already exist when using local exchange mode.
EXCHANGE_DOCKER_NETWORK=final_exchange_default
